# =============================================================================
# DMRE backend — environment variables
# Copy to .env for local development; set as environment variables in Render
# (or any other host). Every variable below has a code default, but you SHOULD
# override JWT_SECRET and CORS_ORIGINS in any non-development deploy.
# =============================================================================

# ---- PostgreSQL ----
# Render's managed Postgres injects DATABASE_URL automatically; you only need to
# add the asyncpg+postgres driver scheme. The sync URL is used by Alembic.
DATABASE_URL=postgresql+asyncpg://dmre:dmre_pass@localhost:5432/dmre_db
DATABASE_URL_SYNC=postgresql://dmre:dmre_pass@localhost:5432/dmre_db

# ---- ChromaDB ----
# "embedded" runs inside the FastAPI process and persists to CHROMA_PERSIST_DIR.
# Set CHROMA_PERSIST_DIR to a path mounted on a persistent disk so vectors
# survive deploys (Render: mount the disk at /data; the default below assumes that).
CHROMA_MODE=embedded
CHROMA_PERSIST_DIR=/data/chroma
CHROMA_COLLECTION=dmre_memories

# ---- Auth ----
# JWT_SECRET MUST be a long random string in production. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=replace-me-with-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200   # 30 days

# ---- CORS ----
# Comma-separated list of allowed origins. Include the production dashboard
# origin before going live. The chrome-extension://* wildcard below is
# replaced automatically by EXTENSION_ID when that is set.
CORS_ORIGINS=http://localhost:3000,chrome-extension://*

# ---- Chrome Extension ID (production only) ----
# After Chrome Web Store submission, set this to the 32-char extension ID
# (shown at chrome://extensions or in the Web Store developer console).
# This replaces the chrome-extension://* wildcard with a specific origin
# so only your published extension can reach the backend.
EXTENSION_ID=

# ---- API Docs ----
# Set to false in production to hide /docs and /redoc.
ENABLE_DOCS=true

# ---- Blockchain (optional) ----
# Leave both blank to disable on-chain anchoring. The /api/memories endpoint
# silently skips it; /api/verify reports the memory as not-anchored.
GANACHE_RPC_URL=
CONTRACT_ADDRESS=

# ---- SMTP (REQUIRED for OTP email verification + email-export) ----
# DMRE will not let users sign up unless this is configured. There is no
# console / mock fallback — production must use a real SMTP server.
#
# Pick ONE provider:
#
#   ▸ Resend (recommended, free 100/day):
#       SMTP_HOST=smtp.resend.com   SMTP_PORT=587   SMTP_TLS=starttls
#       SMTP_USER=resend            SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxx
#       SMTP_FROM=DMRE <notifications@yourdomain.com>
#
#   ▸ Mailgun (free 5k/month for 3 months):
#       SMTP_HOST=smtp.mailgun.org  SMTP_PORT=587   SMTP_TLS=starttls
#       SMTP_USER=postmaster@mg.yourdomain.com
#       SMTP_PASS=<your mailgun password>
#       SMTP_FROM=DMRE <noreply@mg.yourdomain.com>
#
#   ▸ SendGrid (free 100/day forever):
#       SMTP_HOST=smtp.sendgrid.net SMTP_PORT=587   SMTP_TLS=starttls
#       SMTP_USER=apikey            SMTP_PASS=SG.xxxxxxxxxxxxxxxxxx
#       SMTP_FROM=DMRE <verified@yourdomain.com>
#
#   ▸ Gmail with an app password (free, ~tens of emails/day):
#       SMTP_HOST=smtp.gmail.com    SMTP_PORT=587   SMTP_TLS=starttls
#       SMTP_USER=you@gmail.com     SMTP_PASS=<16-char Google App Password>
#       SMTP_FROM=DMRE <you@gmail.com>
#
#   ▸ Local development (run `python backend/dev_smtp.py` in a separate shell):
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_TLS=none
SMTP_FROM=DMRE <noreply@dmre.local>

# Used inside email bodies to link back to the dashboard.
APP_BASE_URL=http://localhost:3000

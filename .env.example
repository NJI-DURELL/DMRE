# =============================================================================
# DMRE Environment Variables Template
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=dmre
POSTGRES_PASSWORD=dmre_pass
POSTGRES_DB=dmre_db

# Async URL used by the FastAPI app (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://dmre:dmre_pass@localhost:5432/dmre_db
# Sync URL used by Alembic migrations (psycopg2 driver)
DATABASE_URL_SYNC=postgresql://dmre:dmre_pass@localhost:5432/dmre_db

# --- ChromaDB ---
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=dmre_memories

# --- Ganache / Blockchain ---
# Start Ganache on port 7545 before running the backend
GANACHE_RPC_URL=http://127.0.0.1:7545
# Populated automatically after running: cd blockchain && npx hardhat run scripts/deploy.js
CONTRACT_ADDRESS=

# --- Application ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_generate_a_strong_random_secret_here
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

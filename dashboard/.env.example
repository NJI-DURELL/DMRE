# =============================================================================
# Dashboard build-time configuration.
#
# Vite inlines `VITE_*` vars at build time. The dashboard's axios client
# (src/services/auth.js) reads VITE_BACKEND_URL and falls back to "/api"
# (the dev proxy in vite.config.js).
#
# Copy this file to `.env.production` and edit the value before running
# `npm run build`, OR set VITE_BACKEND_URL in your hosting provider's
# build environment (Render does this via `sync: false` in render.yaml).
#
# Do NOT include a trailing slash.
# =============================================================================

VITE_BACKEND_URL=https://dmre-backend.onrender.com
